  / VARINT-MULTIBYTE-1 — multi-byte LEB128 format-code decode path exists +
    surfaces unsupported_content_hash_format for an unallocated integer.       /

  {
    "id": "varint-multibyte.1",
    "description": "system/hash with format-code bytes 80 01 (LEB128 of integer 128); impl decodes the multi-byte varint AND surfaces unsupported_content_hash_format (128 not in §1.2 seed table). Pins multi-byte LEB128 decoder existence.",
    "kind": "decode_reject",
    "input_format_code_varint": h'8001',
    "input_decoded_integer": 128,
    "expected_error_code": "unsupported_content_hash_format",
    "expected_status": 400
  },

  / VARINT-RESERVED-FF-1 — integer 255 reserved on both axes per §1.2 / §1.5. /

  {
    "id": "varint-reserved-ff.1.key_type",
    "description": "system/peer mint with key_type integer 255 (varint FF 01); impl MUST refuse — 255 reserved per §1.5",
    "kind": "decode_reject",
    "input_key_type_varint": h'ff01',
    "input_decoded_integer": 255,
    "expected_behavior": "mint refused; error class unspecified (impls MAY use unsupported_key_type or a structural validation error; pinned only as: 'the entity does not construct')"
  },

  {
    "id": "varint-reserved-ff.2.hash_format",
    "description": "system/hash with format-code integer 255 (varint FF 01); MUST surface unsupported_content_hash_format",
    "kind": "decode_reject",
    "input_format_code_varint": h'ff01',
    "input_decoded_integer": 255,
    "expected_error_code": "unsupported_content_hash_format",
    "expected_status": 400
  },

  / FORMAT-CODE-INTERPRETATION-1 — unallocated single-byte format code →
    interpretation error (not a dispatch/routing miss). Renamed from v7.66
    PREFIX-DISPATCH-1 per the v7.68 §1.2 reframe.                              /

  {
    "id": "format-code-interpretation.1",
    "description": "system/hash with single-byte format-code 0x42 (unallocated); impl MUST surface unsupported_content_hash_format. The error is an INTERPRETATION error per §1.2 v7.68 reframe — format-code is intrinsic to the hash, not a routing prefix.",
    "kind": "decode_reject",
    "input_format_code_byte": h'42',
    "expected_error_code": "unsupported_content_hash_format",
    "expected_status": 400
  },

  / ─────────────────────────────────────────────────────────────────────── /
  / PHASE 2 — cross-key/cross-hash matrix (LOCKED, byte-pinned)              /
  / ─────────────────────────────────────────────────────────────────────── /
  / The three matrix vectors share a structural shape: handshake → tree-get
    → cap grant A→B → cap use B→A. Per SEEDS.md §2.2, all three negotiate
    to active format SHA-256 (the standard-compliance fallback path).
    Per SEEDS.md §2.4, identity references use each peer's HOME format;
    cap-token content travels under the ACTIVE format. Per SEEDS.md §2.5,
    A's signature is over the cap-token's wire content_hash (RFC 8032
    deterministic).

    Phase-2 byte pins LOCKED from 3-way cohort round-trip
    (Go post-fix 3cfb353, Rust d38d1f8, Python a2463be — all byte-equal
    on the 7 gates: pubkeys, peer_ids, home content_hashes, cap-data
    CBOR, active cap content_hash, signature, .cbor sha256). Cohort
    closeouts recorded in the per-impl validation docs.

    Empty-scope dimension convention (arch ruling, see
    reviews/RULING-EMPTY-SCOPE-INCLUDE.md): an unconstrained
    scope dimension is present-with-empty-`include` `{include: []}`
    (CBOR `0x80`), NOT absent and NOT `{include: null}` (`0xf6`). Bound
    by ENTITY-CBOR-ENCODING §232 (fields MUST NOT be dropped) +
    §3.6 list-of(pattern) typing (null is not a valid value of a
    list field). The matrix `grants` entries below carry `handlers`
    and `operations` keys explicitly per this ruling.                          /

